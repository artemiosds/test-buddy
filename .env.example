# =============================================================================
# Health Payroll Manager — Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e preencha os valores.
# Variáveis VITE_* são embedadas no bundle do frontend em tempo de build.
# Variáveis sem VITE_ são lidas apenas no servidor (server-side / SSR).
# =============================================================================

# --- Supabase (obrigatórias) ---

# URL do projeto Supabase (pública — mesma para frontend e backend)
VITE_SUPABASE_URL="https://SEU_PROJECT.supabase.co"
SUPABASE_URL="https://SEU_PROJECT.supabase.co"

# Anon key (pública — segura para o frontend, protegida por RLS)
VITE_SUPABASE_PUBLISHABLE_KEY="eyJhbGciOi..."
SUPABASE_PUBLISHABLE_KEY="eyJhbGciOi..."

# Service Role Key (SECRET — apenas server-side! NUNCA exponha ao frontend)
# Usada em server functions, cron jobs, e operações admin que bypassam RLS
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi..."

# Aliases aceitos como fallback (mesmo propósito do SERVICE_ROLE_KEY)
# SERVICE_ROLE_KEY="eyJhbGciOi..."
# SUPABASE_ADMIN_KEY="eyJhbGciOi..."

# --- Cron Jobs (opcional) ---

# Secret compartilhado para autenticar chamadas do cron endpoint
# Se não definido, o endpoint aceita requisições sem autenticação
DEADLINE_CRON_SECRET=""

# --- Build / Deploy (opcional) ---

# Força um preset Nitro específico no build
# Valores: node-server, vercel, cloudflare-module, bun, deno, etc.
# NITRO_PRESET=node-server
